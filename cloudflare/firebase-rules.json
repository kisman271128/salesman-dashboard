{
  "rules": {
    "users": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "visits": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$nik": {
        "$visitId": {
          ".validate": "newData.hasChildren(['outlet_name'])"
        }
      }
    },
    "current_positions": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$nik": {
        ".validate": "newData.hasChildren(['latitude', 'longitude', 'timestamp'])",
        "latitude": {
          ".validate": "newData.isNumber() && newData.val() >= -90 && newData.val() <= 90"
        },
        "longitude": {
          ".validate": "newData.isNumber() && newData.val() >= -180 && newData.val() <= 180"
        }
      }
    },
    "plan_dap": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$nik": {
        "$date": {
          ".validate": "$date.matches(/^[0-9]{4}-[0-9]{2}-[0-9]{2}$/)"
        }
      }
    },
    "daily_summary": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$nik": {
        "$date": {
          ".validate": "newData.hasChildren() && $date.matches(/^[0-9]{4}-[0-9]{2}-[0-9]{2}$/)"
        }
      }
    },
    "sku_pom_checklist": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$nik": {
        "$date": {
          ".validate": "$date.matches(/^[0-9]{4}-[0-9]{2}-[0-9]{2}$/)"
        }
      }
    },
    "connection_test": {
      ".read": true,
      ".write": false
    },
    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
